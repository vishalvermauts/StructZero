# BlueprintForge Environment Variables
# Copy this file to .env and fill in your real API keys
# DO NOT commit your .env file to Git

# Required: Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Anthropic Claude API Key
# Get yours at: https://console.anthropic.com/
CLAUDE_API_KEY=your_anthropic_api_key_here

# Required: DeepSeek API Key
# Get yours at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: Local Ollama URL (for offline/free generation)
OLLAMA_URL=http://localhost:11434
